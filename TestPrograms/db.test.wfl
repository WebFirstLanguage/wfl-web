// Data-layer tests. Run from the repo root:
//   wfl --test TestPrograms/db.test.wfl
include from "../app/db.wfl"

describe "Scriptorium data layer":

    test "migrate creates tables and is idempotent":
        open database at "sqlite::memory:" as conn
        store a as db_migrate of conn
        store b as db_migrate of conn
        store users as query conn with "SELECT count(*) AS n FROM users"
        store row0 as users[0]
        expect row0["n"] to equal 0
        close database conn
    end test

    test "users: create, count, lookup by name and id":
        open database at "sqlite::memory:" as conn
        store m as db_migrate of conn
        expect user_count of conn to equal 0
        store ins as user_create of conn and "ada" and "hash1" and "admin"
        expect user_count of conn to equal 1
        store u as user_by_username of conn and "ada"
        expect u["username"] to equal "ada"
        expect u["role"] to equal "admin"
        store u2 as user_by_id of conn and u["id"]
        expect u2["username"] to equal "ada"
        store no_user as user_by_username of conn and "nobody"
        expect no_user to equal nothing
        close database conn
    end test

    test "settings: default, get with fallback, set/overwrite":
        open database at "sqlite::memory:" as conn
        store m as db_migrate of conn
        expect setting_get of conn and "site_title" and "Fallback" to equal "Fallback"
        store d as setting_default of conn and "site_title" and "Scriptorium"
        expect setting_get of conn and "site_title" and "Fallback" to equal "Scriptorium"
        store d2 as setting_default of conn and "site_title" and "Ignored"
        expect setting_get of conn and "site_title" and "Fallback" to equal "Scriptorium"
        store s as setting_set of conn and "site_title" and "My Blog"
        expect setting_get of conn and "site_title" and "Fallback" to equal "My Blog"
        close database conn
    end test

    test "posts: create, fetch by slug, list published excludes drafts":
        open database at "sqlite::memory:" as conn
        store m as db_migrate of conn
        store au as user_create of conn and "ada" and "h" and "admin"
        store p1 as post_create of conn and "first-post" and "First Post" and "Hello **world**" and "published" and 1
        store p2 as post_create of conn and "draft-post" and "A Draft" and "wip" and "draft" and 1
        store got as post_by_slug of conn and "first-post"
        expect got["title"] to equal "First Post"
        expect got["author_name"] to equal "ada"
        expect post_count_published of conn to equal 1
        store published as post_list_published of conn and 10 and 0
        expect length of published to equal 1
        store head as published[0]
        expect head["slug"] to equal "first-post"
        close database conn
    end test

    test "sessions: create, resolve to user, delete":
        open database at "sqlite::memory:" as conn
        store m as db_migrate of conn
        store au as user_create of conn and "ada" and "h" and "admin"
        store uid as 1
        store sc as session_create of conn and "sid-abc" and uid and "2999-01-01 00:00:00" and "tok-1"
        store who as session_user of conn and "sid-abc"
        expect who["username"] to equal "ada"
        store gone as session_delete of conn and "sid-abc"
        store after as session_user of conn and "sid-abc"
        expect after to equal nothing
        close database conn
    end test

    test "sessions: carry a csrf token that session_user returns":
        open database at "sqlite::memory:" as conn
        store m as db_migrate of conn
        store au as user_create of conn and "ada" and "h" and "admin"
        store sc as session_create of conn and "sid-tok" and 1 and "2999-01-01 00:00:00" and "csrf-abc123"
        store who as session_user of conn and "sid-tok"
        expect who["csrf_token"] to equal "csrf-abc123"
        close database conn
    end test

    test "pages: list_by_author scopes to the owner":
        open database at "sqlite::memory:" as conn
        store m as db_migrate of conn
        store a1 as user_create of conn and "ada" and "h" and "admin"
        store a2 as user_create of conn and "bob" and "h" and "author"
        store pg1 as page_create of conn and "about" and "About" and "x" and "published" and 1
        store pg2 as page_create of conn and "contact" and "Contact" and "y" and "published" and 2
        store all_pages as page_list_all of conn
        expect length of all_pages to equal 2
        store bobs as page_list_by_author of conn and 2
        expect length of bobs to equal 1
        store head as bobs[0]
        expect head["slug"] to equal "contact"
        store got as page_by_id of conn and 1
        expect got["author_id"] to equal 1
        close database conn
    end test

    test "sessions: expired session does not resolve":
        open database at "sqlite::memory:" as conn
        store m as db_migrate of conn
        store au as user_create of conn and "ada" and "h" and "admin"
        store sc as session_create of conn and "sid-old" and 1 and "2000-01-01 00:00:00" and "tok-old"
        store who as session_user of conn and "sid-old"
        expect who to equal nothing
        close database conn
    end test

    test "migrate upgrades a legacy sessions table with a csrf_token column":
        open database at "sqlite::memory:" as conn
        store legacy as execute conn with "CREATE TABLE sessions (id TEXT PRIMARY KEY, user_id INTEGER NOT NULL, created_at TEXT DEFAULT (datetime('now')), expires_at TEXT NOT NULL)"
        store m as db_migrate of conn
        store ins as execute conn with "INSERT INTO sessions (id, user_id, expires_at, csrf_token) VALUES ('s1', 1, '2999-01-01 00:00:00', 'tok')"
        store rows as query conn with "SELECT csrf_token FROM sessions WHERE id = 's1'"
        store row0 as rows[0]
        expect row0["csrf_token"] to equal "tok"
        close database conn
    end test

    test "media: create, list newest first, fetch by id, delete":
        open database at "sqlite::memory:" as conn
        store m as db_migrate of conn
        store au as user_create of conn and "ada" and "h" and "admin"
        store m1 as media_create of conn and "cat-a1b2.png" and "cat.png" and "image/png" and 1234 and 1
        store m2 as media_create of conn and "dog-c3d4.jpg" and "dog photo.jpg" and "image/jpeg" and 5678 and 1
        store rows as media_list_all of conn
        expect length of rows to equal 2
        store head as rows[0]
        expect head["filename"] to equal "dog-c3d4.jpg"
        expect head["original_name"] to equal "dog photo.jpg"
        expect head["uploader_name"] to equal "ada"
        store media_row as media_by_id of conn and 1
        expect media_row["filename"] to equal "cat-a1b2.png"
        expect media_row["size"] to equal 1234
        store del as media_delete of conn and 1
        store after_rows as media_list_all of conn
        expect length of after_rows to equal 1
        store gone as media_by_id of conn and 1
        expect gone to equal nothing
        close database conn
    end test

    test "login attempts: record, count within window, clear":
        open database at "sqlite::memory:" as conn
        store m as db_migrate of conn
        expect login_attempts_recent of conn and "10.0.0.1" to equal 0
        store a1 as login_attempt_record of conn and "10.0.0.1"
        store a2 as login_attempt_record of conn and "10.0.0.1"
        store a3 as login_attempt_record of conn and "10.0.0.2"
        expect login_attempts_recent of conn and "10.0.0.1" to equal 2
        expect login_attempts_recent of conn and "10.0.0.2" to equal 1
        store c as login_attempts_clear of conn and "10.0.0.1"
        expect login_attempts_recent of conn and "10.0.0.1" to equal 0
        expect login_attempts_recent of conn and "10.0.0.2" to equal 1
        close database conn
    end test

    test "login attempts: old attempts fall outside the window and purge":
        open database at "sqlite::memory:" as conn
        store m as db_migrate of conn
        store old as execute conn with "INSERT INTO login_attempts (ip, attempted_at) VALUES (?, datetime('now', '-1 hour'))" and parameters ["10.0.0.9"]
        expect login_attempts_recent of conn and "10.0.0.9" to equal 0
        store p as login_attempts_purge of conn
        store rows as query conn with "SELECT count(*) AS n FROM login_attempts"
        store row0 as rows[0]
        expect row0["n"] to equal 0
        close database conn
    end test

end describe
